# ── Server ────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,http://127.0.0.1:3000

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MINUTES=1

# ── Cache ─────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=300
CACHE_MAX_KEYS=500

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs
LOG_RETENTION_DAYS=14

# ── Steam API ─────────────────────────────────────────────────────
STEAM_API_BASE_URL=https://api.steampowered.com
STEAM_REQUEST_TIMEOUT_MS=10000
STEAM_API_KEY_LENGTH=32
